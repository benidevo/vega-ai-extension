#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# Run linting on staged files only
npx lint-staged || { echo "Linting failed. Fix errors before committing."; exit 1; }

# Run type checking
npm run typecheck || { echo "Type checking failed. Fix errors before committing."; exit 1; }

echo "Pre-commit checks passed!"
